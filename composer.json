{
    "name": "alangiacomin/laravel-base-pack",
    "description": "Laravel base pack",
    "license": "MIT",
    "keywords": [
        "alangiacomin",
        "base",
        "laravel",
        "laravel-base-pack"
    ],
    "homepage": "https://github.com/alangiacomin/laravel-base-pack",
    "authors": [
        {
            "name": "Alan Giacomin",
            "email": "alan.giacomin@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "alangiacomin/php-utils": "v1.2.0"
    },
    "require-dev": {
        "laravel/framework": "v11.29.0",
        "laravel/pint": "v1.18.1",
        "phpunit/phpunit": "11.4.3",
        "orchestra/testbench": "v9.5.2"
    },
    "autoload": {
        "psr-4": {
            "Alangiacomin\\LaravelBasePack\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "./vendor/bin/phpunit --no-coverage"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alangiacomin\\LaravelBasePack\\LaravelBasePackServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
